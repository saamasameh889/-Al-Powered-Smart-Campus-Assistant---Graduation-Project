# AI-Powered Smart Campus Assistant — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#
#   copy .env.example .env    (Windows)
#   cp .env.example .env      (macOS / Linux)

# ── REQUIRED — OpenAI API Key ─────────────────────────────────────────────────
# Used for: RAG answer generation (GPT-4o-mini) + document embeddings
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-openai-key-here...

# ── OPTIONAL — Google Classroom OAuth (Product B import) ─────────────────────
# Required only for the "Connect Google Classroom" feature.
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
#        → Create OAuth 2.0 Client ID → Web Application
#        → Add http://localhost:8501 to Authorized redirect URIs
GOOGLE_CLIENT_ID=...your-client-id....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...your-client-secret...
GOOGLE_REDIRECT_URI=http://localhost:8501
